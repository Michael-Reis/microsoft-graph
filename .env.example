# Copie este arquivo para .env e preencha os valores.
# .env esta no .gitignore e NAO deve ser commitado.

# --- Microsoft Entra ID (App Registration) ---
CLIENT_ID=
CLIENT_SECRET=
AUTHORITY=https://login.microsoftonline.com/<TENANT_ID_OU_DOMINIO>
REDIRECT_URI=http://localhost:3000/microsoft/callback

# --- Conta remetente no Teams (fluxo ROPC: precisa de licenca e SEM MFA) ---
MICROSOFT_GRAPH_ROPC_USER=noreply@orit.com.br
MICROSOFT_GRAPH_ROPC_PASSWORD=

# --- Banco de dados MySQL (fluxo OneDrive/valuation) ---
DATABASE_URL=mysql://root:@localhost:3306/orit

# --- App ---
PORT=3000

# --- OpenAI ---
OPENIA_KEY=

# --- Chave de admin do gerenciador de tokens (header x-admin-key em /tokens) ---
ADMIN_API_KEY=

# --- Redis (fila de envio - BullMQ) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
